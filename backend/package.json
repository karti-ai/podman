{
  "name": "@podman/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "pnpm run dev:server",
    "dev:server": "tsx watch src/server.ts",
    "dev:agent": "tsx watch src/agent.ts",
    "graph:seed": "tsx src/graph/seed.ts",
    "start": "node dist/server.js",
    "start:server": "node dist/server.js",
    "start:agent": "node dist/agent.js",
    "start:all": "node dist/hermes.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@livekit/rtc-node": "^0.13.29",
    "@podman/shared": "workspace:*",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "livekit-server-sdk": "^2.15.5",
    "mongodb": "^7.4.0",
    "octokit": "^5.0.5",
    "sharp": "^0.35.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4"
  }
}
